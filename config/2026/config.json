  "sections": [
    {
      "name": "Prematch",
      "fields": [
        {
          "title": "Scouter Initials",
          "description": "Enter the initials of the scouter.",
          "type": "text",
          "required": true,
          "code": "scouter",
          "formResetBehavior": "preserve",
          "defaultValue": ""
        },
        {
          "title": "Match Number",
          "description": "Select the match number.",
          "type": "TBA-match-number",
          "required": true,
          "code": "matchNumber",
          "formResetBehavior": "increment",
          "defaultValue": 1
        },
        {
          "title": "Team and Robot",
          "description": "Select the team and robot position you are scouting.",
          "type": "TBA-team-and-robot",
          "required": true,
          "code": "robot",
          "formResetBehavior": "preserve",
          "defaultValue": null
        },
        {
          "title": "Starting Position",
          "description": "The starting position of the robot.",
          "type": "select",
          "required": true,
          "code": "startPos",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "OT": "A. Outpost Trench",
            "OBFT": "B. Outpost Bump Favoring Trench",
            "OBFH": "C. Outpost Bump Favoring Hub",
            "H": "D. Hub",
            "DBFH": "E. Depot Bump Favoring Hub",
            "DBFT": "F. Depot Bump Favoring Trench",
            "DT": "G. Depot Trench"
          }
        },
        {
          "title": "Field Layout: Red",
          "description": "Reference diagram of the field",
          "type": "image",
          "required": false,
          "code": "fieldLayoutR",
          "formResetBehavior": "preserve",
          "defaultValue": "https://i.ibb.co/7Jh1hZXL/Scouting-Field-Map-Layout.png",
          "width": 300,
          "height": 150,
          "alt": "2026 FRC Field Layout Diagram"
        },
        {
          "title": "Field Layout: Blue",
          "description": "Reference diagram of the field",
          "type": "image",
          "required": false,
          "code": "fieldLayoutB",
          "formResetBehavior": "preserve",
          "defaultValue": "https://i.ibb.co/Ldg8Jcbt/Scouting-Field-Map-Layout-2.png",
          "width": 300,
          "height": 150,
          "alt": "2026 FRC Field Layout Diagram"
        }
      ]
    },
    {
      "name": "Autonomous",
      "fields": [
        {
          "title": "Actions",
          "description": "Track actions performed during autonomous.",
          "type": "action-tracker",
          "required": false,
          "code": "autoActions",
          "formResetBehavior": "reset",
          "defaultValue": null,
          "mode": "hold",
          "actions": [
            {
              "label": "Scoring",
              "code": "scoring"
            },
            {
              "label": "Ground Collect",
              "code": "ground_collect"
            },
            {
              "label": "Stuck on fuel or bump",
              "code": "stuck"
            },
            {
              "label": "Climbing",
              "code": "climbing"
            }
          ],
          "timerDuration": 20
        },
        {
          "title": "Climbed",
          "description": "Did the robot climb during autonomous?",
          "type": "select",
          "required": false,
          "code": "autoClimbed",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "No": "No Climb",
            "Yes": "Climb",
            "F": "Failed Climb"
          }
        },
        {
          "title": "Where Climbed",
          "description": "Where on the tower did the robot climb in autonomous?",
          "type": "select",
          "required": false,
          "code": "autoClimbPos",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "No": "No Climb",
            "Out": "Output Side",
            "Mid": "Middle",
            "Dep": "Depot Side"
          }
        }
      ]
    },
    {
      "name": "Teleop",
      "fields": [
        {
          "title": "Actions",
          "description": "Track actions performed during teleop.",
          "type": "action-tracker",
          "required": false,
          "code": "teleopActions",
          "formResetBehavior": "reset",
          "defaultValue": null,
          "mode": "hold",
          "actions": [
            {
              "label": "Scoring",
              "code": "scoring"
            },
            {
              "label": "Passing",
              "code": "passing"
            },
            {
              "label": "Robot Inactive",
              "code": "robot inactive"
            },
            {
              "label": "Defense",
              "code": "defense"
            }
          ],
          "timerDuration": 135
        },
        {
          "title": "Crossed into opposite zone?",
          "description": "Did the robot cross into the opposing alliance's zone?",
          "type": "boolean",
          "required": false,
          "code": "crossedZone",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Mechanical Issue?",
          "description": "Did the robot have a mechanical issue during the match?",
          "type": "boolean",
          "required": false,
          "code": "mechIssue",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Stuck on fuel (less than 10 seconds)?",
          "description": "Did the robot get stuck on fuel during the match for less than 10 seconds?",
          "type": "boolean",
          "required": false,
          "code": "Stuck10-",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Stuck on fuel (more than 10 seconds)?",
          "description": "Did the robot get stuck on fuel during the match for more than 10 seconds?",
          "type": "boolean",
          "required": false,
          "code": "Stuck10+",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Died?",
          "description": "Did the robot die during the match?",
          "type": "boolean",
          "required": false,
          "code": "died",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Tipped/Fell Over",
          "description": "Did the robot tip or fall over during the match?",
          "type": "boolean",
          "required": false,
          "code": "tipped",
          "formResetBehavior": "reset",
          "defaultValue": false
        }
      ]
    },
    {
      "name": "Endgame",
      "fields": [
        {
          "title": "Climbed",
          "description": "The level the robot climbed during endgame.",
          "type": "select",
          "required": true,
          "code": "climbed",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "No": "No Climb",
            "L1": "Level 1",
            "L2": "Level 2",
            "L3": "Level 3",
            "F": "Failed Climb"
          }
        },
        {
          "title": "Where Climbed",
          "description": "Where on the tower did the robot climb?",
          "type": "select",
          "required": false,
          "code": "climbPos",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "No": "No Climb",
            "Out": "Output Side",
            "Mid": "Middle",
            "Dep": "Depot Side"
          }
        }
      ]
    },
    {
      "name": "Postmatch",
      "fields": [
        {
          "title": "Scoring Accuracy (in 20% steps)",
          "description": "Rate the robot's scoring effectiveness. 0 for no scoring, 1 is 20%, 2 is 40%, etc.",
          "type": "range",
          "required": false,
          "code": "scoringAcc",
          "formResetBehavior": "reset",
          "defaultValue": 3,
          "min": 0,
          "max": 5,
          "step": 1
        },
        {
          "title": "Defense Skill",
          "description": "Rate the robot's defensive skill.",
          "type": "range",
          "required": false,
          "code": "defSkill",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "max": 5,
          "step": 1
        },
        {
          "title": "Tags",
          "description": "Add the tags if applicable to the robot for this match",
          "type": "multi-select",
          "required": false,
          "code": "tags",
          "formResetBehavior": "reset",
          "choices": {
            "Slow Driving": "Slow Driving",
            "Fast Driving": "Fast Driving",
            "Slow Intake": "Slow Intake",
            "Fast Intake": "Fast Intake",
            "Slow Scoring": "Slow Scoring",
            "Fast Scoring": "Fast Scoring",
            "Good at passing": "Good at passing",
            "In the way": "In the way of partners",
            "Good at pushing fuel": "Good at pushing fuel",
            "Passed from opponent's zone": "Passed from opponent's zone"
          }
        },
        {
          "title": "Comments",
          "type": "text",
          "required": false,
          "code": "co",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "min": 0,
          "max": 100
        }
      ]
    }
  ]
}
